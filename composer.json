{
  "name": "attendance/professional-system",
  "description": "Attendance workflow system with CR submission, lecturer approval, signed sheets, and Marazone sync.",
  "type": "project",
  "require": {
    "php": "^8.3",
    "nikic/fast-route": "^1.3",
    "vlucas/phpdotenv": "^5.6",
    "monolog/monolog": "^3.8"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "migrate": "php scripts/migrate.php",
    "migrate:down": "php scripts/migrate_down.php",
    "seed": "php scripts/seed.php",
    "escalate": "php scripts/run_escalations.php",
    "sync:marazone": "php scripts/sync_marazone.php",
    "test:smoke": "php tests/smoke/workflow_smoke.php"
  }
}
